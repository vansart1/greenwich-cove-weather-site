// Cloudflare Workers Builds config.
// A small Worker script (src/worker.js) handles the /refresh endpoint and falls
// through to static assets for everything else.
{
  "name": "greenwich-cove-weather-site",
  "compatibility_date": "2025-01-01",
  "main": "src/worker.js",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  }
}
